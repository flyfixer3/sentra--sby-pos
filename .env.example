APP_NAME="Stefanus POS"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://internal.sentraautoglass.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# ─── CORS ────────────────────────────────────────────────────────────────────
# All three frontend origins must be listed (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=https://crm.sentraautoglass.com,https://crm-sentra.vercel.app,https://sentraautoglass.vercel.app
CORS_SUPPORTS_CREDENTIALS=false

# ─── Sanctum ─────────────────────────────────────────────────────────────────
# CRM uses Bearer token auth — stateful domains only matter for SPA cookie auth
SANCTUM_STATEFUL_DOMAINS=internal.sentraautoglass.com

# ─── CRM API ─────────────────────────────────────────────────────────────────
# MUST be false in production — true disables all authentication (dev only!)
CRM_API_NO_AUTH=false

# ─── Queue ───────────────────────────────────────────────────────────────────
# Use redis + Supervisor in production. sync blocks HTTP responses.
QUEUE_CONNECTION=redis

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_DRIVER=redis

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_INACTIVITY_TIMEOUT=120
SESSION_INACTIVITY_WARNING=1

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=your_smtp_host
MAIL_PORT=587
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@sentraautoglass.com
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage ─────────────────────────────────────────────────────────────────
FILESYSTEM_DRIVER=local

DEBUGBAR_ENABLED=false
